# Copy this file to `keystore.properties` (same directory) and fill in the
# real values. `keystore.properties` is gitignored — never commit it.
#
# storeFile is resolved relative to this android/ directory.

storeFile=app/maxiedit-release.keystore
storePassword=REPLACE_WITH_KEYSTORE_PASSWORD
keyAlias=maxiedit
keyPassword=REPLACE_WITH_KEY_PASSWORD
